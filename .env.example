# INDmoney Live Market Quota API Token (optional but required for live LTP updates)
# Get your token from: https://api.indstocks.com/ (or relevant documentation)
INDSTOCKS_TOKEN="your_indstocks_jwt_token_here"

# Telegram Bot Configuration (optional, for alerts and notifications)
# Create a bot via @BotFather on Telegram to get your token
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Your Telegram Chat ID (optional, where alerts will be sent)
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"